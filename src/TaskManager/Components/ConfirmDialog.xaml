<UserControl x:Class="TaskManager.Components.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskManager.Components"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=System"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel MaxWidth="800">
        <TextBlock Margin="10 20" TextAlignment="Center" TextWrapping="Wrap"
                   Text="{Binding Message}"
                   d:Text="Вы уверены?"/>
        <UniformGrid Columns="2">
            <Button Content="Подтвердить" Command="{x:Static md:DialogHost.CloseDialogCommand}" CommandParameter="Confirm" Margin="5"/>
            <Button Style="{DynamicResource MaterialDesignFlatButton}" Content="Отмена" Command="{x:Static md:DialogHost.CloseDialogCommand}" CommandParameter="Cancel" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</UserControl>
