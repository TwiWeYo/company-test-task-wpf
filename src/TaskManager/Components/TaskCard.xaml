<UserControl x:Class="TaskManager.Components.TaskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskManager.Components" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             
             FontFamily="{materialDesign:MaterialDesignFont}"
             
             mc:Ignorable="d" 
             d:DesignWidth="350">
    <Border CornerRadius="0" Background="White" materialDesign:ShadowAssist.CacheMode="BitmapCache">
        <Grid x:Name="Main">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="8*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid x:Name="Info" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Test Title need to be bounded" VerticalAlignment="Center" FontSize="16" Margin="5 0" Foreground="Black" FontWeight="Bold" Grid.Column="0"/>
                <Button Style="{StaticResource MaterialDesignToolForegroundButton}" Width="30" Height="30" Grid.Column="1">
                    <materialDesign:PackIcon Kind="Pencil" Foreground="Blue"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignToolForegroundButton}" Width="30" Height="30" Grid.Column="2">
                    <materialDesign:PackIcon Kind="Delete" Foreground="Red"/>
                </Button>
            </Grid>
            <Border CornerRadius="0" Margin="5" Grid.Row="1">
                <DockPanel x:Name="Body" LastChildFill="True" >
                    <Border Margin="5" Padding="5" HorizontalAlignment="Left" Background="Blue" DockPanel.Dock="Bottom">
                        <TextBlock Text="Status" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua" Margin="5" TextWrapping="Wrap"/>
                </DockPanel>
            </Border>
            <DockPanel Grid.Row="2">
                <materialDesign:PackIcon Kind="LowPriority" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <TextBlock Text="Created at: 14.03.2026" Margin="5" DockPanel.Dock="Left"/>
                <TextBlock Text="Due: 17.03.2026" Margin="5" TextAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
