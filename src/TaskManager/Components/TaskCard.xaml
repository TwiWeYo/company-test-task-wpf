<UserControl x:Class="TaskManager.Components.TaskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TaskManager.Components"
             xmlns:utils="clr-namespace:TaskManager.Utils"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         
             FontFamily="{materialDesign:MaterialDesignFont}"
             
             mc:Ignorable="d" 
             d:DesignWidth="300">
    <materialDesign:Card>
        <Grid x:Name="Main">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="8*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid x:Name="Info" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{DynamicResource MaterialDesignTitleMediumTextBlock}" VerticalAlignment="Bottom" Margin="5" TextWrapping="Wrap" Grid.Column="0"
                           Text="{Binding Path=Title}"
                           d:Text="Title"/>
                <Button Style="{DynamicResource MaterialDesignToolForegroundButton}" Grid.Column="1" 
                        Command="{Binding Path=DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                        CommandParameter="{Binding}">
                    <materialDesign:PackIcon Kind="Pencil" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                </Button>
                <Button Style="{DynamicResource MaterialDesignToolForegroundButton}" Grid.Column="2"
                        Command="{Binding Path=DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                        CommandParameter="{Binding}">
                    <materialDesign:PackIcon Kind="Delete" Foreground="Red"/>
                </Button>
            </Grid>
            <Border Margin="5" Grid.Row="1">
                <DockPanel x:Name="Body" LastChildFill="True">
                    <DockPanel DockPanel.Dock="Bottom">

                        <Border Background="{Binding Path=Priority, Converter={utils:PriorityToColorConverter}}" Margin="10" Padding="5" DockPanel.Dock="Right">
                            <Label VerticalAlignment="Center"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                   Content="{Binding Path=Priority, Converter={utils:EnumToDescriptionConverter}}"
                                    d:Content="Low"/>
                        </Border>
                        <ComboBox materialDesign:HintAssist.Hint="Статус"
                                  ItemsSource="{Binding Path=Status, Converter={utils:EnumToCollectionConverter}, Mode=OneTime}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Description"
                                  SelectedValue="{Binding Path=Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        </ComboBox>
                    </DockPanel>
                    <TextBlock Style="{DynamicResource MaterialDesignBodySmallTextBlock}" Margin="5" TextWrapping="Wrap"
                               Text="{Binding Path=Description}"
                               d:Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua"/>

                </DockPanel>
            </Border>
            <DockPanel Grid.Row="2">
                <TextBlock Margin="5" FontSize="10" DockPanel.Dock="Left"
                           Text="{Binding Path=CreatedAt, StringFormat='Создано: {0}', Converter={utils:DateToFormattedStringConverter}}"
                           d:Text="Создано: 14.03.2026"/>
                <TextBlock Margin="5" TextAlignment="Right" FontSize="10" DockPanel.Dock="Right"
                           Text="{Binding Path=DueDate, StringFormat='Срок до: {0}', Converter={utils:DateToFormattedStringConverter}}"
                           d:Text="Срок до: 17.03.2026"/>
                <materialDesign:PackIcon Kind="Warning" Foreground="DarkOrange" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"
                                         Visibility="{Binding Path=DueDate, Converter={utils:DateToVisibilityConverter}}"/>
            </DockPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
